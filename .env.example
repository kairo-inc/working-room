# Database
DATABASE_URL=file:./dev.db

# Auth (NextAuth)
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=""

# AI providers (at least one required)
ANTHROPIC_API_KEY=""
OPENAI_API_KEY=""

# If true, the web app allows multiple tenants to be created.
# NOTE: Multi-tenant mode is currently not available.
MULTI_TENANT=false

# Optional
# Path to the workspace directory where files are stored.
# Default is ~/.wr
# ROOT_DIR=./workspace